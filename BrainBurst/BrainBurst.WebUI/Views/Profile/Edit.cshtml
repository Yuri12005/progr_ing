@{
    ViewData["Title"] = "Редагування профілю";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        padding-top: 20px;
    }

    .page-title {
        font-size: 36px;
        font-weight: 800;
        margin-top: 0;
        margin-bottom: 40px;
        color: black;
        text-align: center;
    }

    .edit-form {
        display: flex;
        flex-direction: column;
        gap: 30px;
        width: 100%;
        max-width: 500px;
    }

    /* Блок редагування аватарки */
    .avatar-edit-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 15px;
    }

    .avatar-preview {
        width: 120px;
        height: 120px;
        background-color: #E0E0E0;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 50px;
        overflow: hidden;
        border: 3px solid #FF3B30;
    }

    .btn-change-photo {
        background-color: transparent;
        color: #FF3B30;
        border: none;
        font-size: 16px;
        font-weight: 700;
        cursor: pointer;
        text-decoration: underline;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .form-label {
        font-weight: 800;
        font-size: 18px;
        margin-left: 5px;
        color: #FF3B30;
    }

    .input-field {
        background-color: #D9D9D9;
        border: none;
        border-radius: 12px;
        padding: 18px 25px;
        font-size: 18px;
        font-family: 'Inter', sans-serif;
        font-weight: 600;
        color: #333;
        width: 100%;
        box-sizing: border-box;
        outline: none;
    }

    .button-group {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-top: 10px;
    }

    .btn-submit {
        background-color: black;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-size: 18px;
        font-weight: 700;
        cursor: pointer;
        text-align: center;
        transition: opacity 0.2s;
    }

        .btn-submit:hover {
            opacity: 0.8;
        }

    .btn-cancel {
        background-color: transparent;
        color: black;
        border: 2px solid #D9D9D9;
        border-radius: 12px;
        padding: 14px; /* Трохи менший падінг через рамку */
        font-size: 18px;
        font-weight: 700;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        transition: background-color 0.2s;
    }

        .btn-cancel:hover {
            background-color: #EFEFEF;
        }
</style>

<div class="form-wrapper">
    <h1 class="page-title">Редагування профілю</h1>

    <form class="edit-form" action="/Profile/Edit" method="post">

        <div class="avatar-edit-section">
            <div class="avatar-preview">☁️</div>
            <button type="button" class="btn-change-photo">Змінити фото</button>
        </div>

        <div class="form-group">
            <div class="form-label">Ім'я користувача</div>
            <input type="text" name="username" class="input-field" value="@ViewBag.CurrentUsername" required>
        </div>

        <div class="button-group">
            <button type="submit" class="btn-submit">Зберегти зміни</button>
            <a href="/Profile" class="btn-cancel">Скасувати</a>
        </div>

    </form>
</div>