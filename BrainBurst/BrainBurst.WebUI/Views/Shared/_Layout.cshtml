<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BrainBurst</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            display: flex;
            height: 100vh;
            background-color: white;
        }

        /* Червоний сайдбар зліва */
        .sidebar {
            width: 80px;
            background-color: #FF3B30;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 20px;
            flex-shrink: 0;
        }

        .sidebar-logo {
            width: 50px;
            margin-bottom: 40px;
            cursor: pointer;
        }

        .nav-icons {
            display: flex;
            flex-direction: column;
            gap: 30px;
            align-items: center;
            width: 100%;
        }

        .nav-link {
            text-decoration: none;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0.7;
            transition: opacity 0.2s;
        }

            .nav-link:hover {
                opacity: 1;
            }

        /* Стиль для самих картинок-іконок */
        .nav-icon-img {
            width: 35px; /* Розмір іконки. Можеш збільшити чи зменшити за потреби */
            height: auto;
        }

        .settings-link {
            margin-top: auto;
            margin-bottom: 30px;
        }

        /* Основний контент справа */
        .main-container {
            flex-grow: 1;
            padding: 40px 60px;
            overflow-y: auto;
        }
    </style>
</head>
<body>

    <nav class="sidebar">
        <a href="/Profile" class="sidebar-logo">
            <img src="/images/logo-black.png" style="width: 100%;" alt="Logo">
        </a>

        <div class="nav-icons">
            <a href="/Cards" class="nav-link" title="Мої картки">
                <img src="/images/cards.png" class="nav-icon-img" alt="Картки">
            </a>

            <a href="/Tests" class="nav-link" title="Тести">
                <img src="/images/tests.png" class="nav-icon-img" alt="Тести">
            </a>

            <a href="/Rating" class="nav-link" title="Рейтинг">
                <img src="/images/achievements.png" class="nav-icon-img" alt="Рейтинг">
            </a>
        </div>

        <a href="/Settings" class="nav-link settings-link" title="Налаштування">
            <img src="/images/settings.png" class="nav-icon-img" alt="Налаштування">
        </a>
    </nav>

    <div class="main-container">
        @RenderBody()
    </div>

</body>
</html>