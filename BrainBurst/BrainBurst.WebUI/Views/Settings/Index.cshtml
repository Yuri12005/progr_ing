@{
    ViewData["Title"] = "Налаштування";
    Layout = "~/Views/Shared/_Layout.cshtml"; // Використовуємо наш шаблон із червоним меню
}

<style>
    .page-title {
        font-size: 32px;
        font-weight: 800;
        margin-top: 0;
        margin-bottom: 20px;
        color: black;
    }

    /* Великий фоновий контейнер (світло-рожевий) */
    .settings-container {
        background-color: #F4E3E0; /* Приблизний колір з мокапу */
        border-radius: 20px;
        padding: 50px;
        min-height: 60vh; /* Щоб блок був достатньо високим */
    }

    /* Блок з аватаркою та ім'ям */
    .profile-section {
        display: flex;
        align-items: center;
        gap: 30px;
        margin-bottom: 50px;
    }

    .avatar {
        width: 140px;
        height: 140px;
        background-color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 60px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

        /* Якщо буде реальна картинка */
        .avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .username-display {
        font-size: 26px;
        font-weight: 800;
        color: black;
    }

    /* Блок з кнопками дій */
    .settings-actions {
        display: flex;
        flex-direction: column;
        gap: 20px;
        width: 320px; /* Ширина кнопок */
    }

    /* Стиль для кнопок-контурів */
    .btn-outline {
        background-color: transparent;
        border: 2px solid #D59B96; /* Темніший рожево-коричневий для рамки */
        color: black;
        border-radius: 12px;
        padding: 16px;
        font-size: 16px;
        font-weight: 700;
        text-align: center;
        cursor: pointer;
        transition: background-color 0.2s, transform 0.1s;
        text-decoration: none;
        display: block; /* Щоб тег <a> поводився як кнопка */
    }

        .btn-outline:hover {
            background-color: #EAC9C4; /* Легке заливання при наведенні */
        }

        .btn-outline:active {
            transform: scale(0.98);
        }
</style>

<h1 class="page-title">Налаштування</h1>

<div class="settings-container">

    <div class="profile-section">
        <div class="avatar">
            ☁️
        </div>
        <div class="username-display">@ViewBag.Username</div>
    </div>

    <div class="settings-actions">
        <a href="/Settings/ChangePassword" class="btn-outline">Змінити пароль</a>

        <a href="/Account/Logout" class="btn-outline">Вийти з акаунту</a>

        <a href="/Settings/DeleteAccount" class="btn-outline" style="color: #FF3B30; border-color: #FF3B30;">Видалити акаунт</a>
    </div>

</div>