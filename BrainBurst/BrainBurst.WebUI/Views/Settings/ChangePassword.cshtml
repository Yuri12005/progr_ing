@{
    ViewData["Title"] = "Зміна пароля";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .form-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 100%;
        padding-top: 20px;
    }

    .page-title {
        font-size: 36px;
        font-weight: 800;
        margin-top: 0;
        margin-bottom: 40px;
        color: black;
        text-align: center;
    }

    .password-form {
        display: flex;
        flex-direction: column;
        gap: 25px;
        width: 100%;
        max-width: 500px; /* Зручна ширина для полів пароля */
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .form-label {
        font-weight: 800;
        font-size: 18px;
        margin-left: 5px;
        color: #FF3B30;
    }

    .input-field {
        background-color: #D9D9D9;
        border: none;
        border-radius: 12px;
        padding: 18px 25px;
        font-size: 18px;
        font-family: 'Inter', sans-serif;
        font-weight: 600;
        color: #333;
        width: 100%;
        box-sizing: border-box;
        outline: none;
    }

    .button-group {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-top: 10px;
    }

    .btn-submit {
        background-color: black;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 16px;
        font-size: 18px;
        font-weight: 700;
        cursor: pointer;
        text-align: center;
        transition: opacity 0.2s;
    }

        .btn-submit:hover {
            opacity: 0.8;
        }

    .btn-cancel {
        background-color: transparent;
        color: black;
        border: 2px solid #D9D9D9;
        border-radius: 12px;
        padding: 14px;
        font-size: 18px;
        font-weight: 700;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        transition: background-color 0.2s;
    }

        .btn-cancel:hover {
            background-color: #EFEFEF;
        }
</style>

<div class="form-wrapper">
    <h1 class="page-title">Зміна пароля</h1>

    <form class="password-form" action="/Settings/ChangePassword" method="post">

        <div class="form-group">
            <div class="form-label">Поточний пароль</div>
            <input type="password" name="oldPassword" class="input-field" placeholder="Введіть старий пароль" required>
        </div>

        <div class="form-group">
            <div class="form-label">Новий пароль</div>
            <input type="password" name="newPassword" class="input-field" placeholder="Введіть новий пароль" required>
        </div>

        <div class="form-group">
            <div class="form-label">Підтвердіть новий пароль</div>
            <input type="password" name="confirmPassword" class="input-field" placeholder="Повторіть новий пароль" required>
        </div>

        <div class="button-group">
            <button type="submit" class="btn-submit">Зберегти пароль</button>
            <a href="/Settings" class="btn-cancel">Скасувати</a>
        </div>

    </form>
</div>