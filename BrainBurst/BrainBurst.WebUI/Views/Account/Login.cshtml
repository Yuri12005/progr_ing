@{
    // Вимикаємо загальне меню, бо сторінка входу має бути чистою
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вхід - BrainBurst</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding-top: 100px; /* Зробили більший відступ зверху */
            font-family: 'Inter', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            background-color: white;
        }

        .logo-container {
            text-align: center;
            margin-bottom: 30px;
        }

        .brain-logo {
            width: 160px;
            height: auto;
            margin-bottom: 10px;
        }

        .brand-title {
            color: #FF3B30;
            font-size: 52px;
            font-weight: 800;
            margin: 0;
            letter-spacing: 1px;
        }

        .form-container {
            width: 500px; /* Поля на мокапі досить широкі */
            display: flex;
            flex-direction: column;
            align-items: center; /* Центруємо кнопку всередині форми */
            gap: 15px;
        }

        .input-field {
            background-color: #D9D9D9;
            border: none;
            border-radius: 12px;
            padding: 16px 20px;
            font-size: 16px;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            color: #333;
            width: 100%;
            box-sizing: border-box;
            outline: none;
        }

            .input-field::placeholder {
                color: #555;
                font-weight: 600;
            }

        .btn-login {
            background-color: black;
            color: white;
            border: none;
            border-radius: 12px;
            padding: 16px 0;
            width: 250px; /* Кнопка коротша за поля, як на мокапі */
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 20px;
            transition: opacity 0.2s;
        }

            .btn-login:hover {
                opacity: 0.8;
            }

        .switch-link {
            margin-top: 15px;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            color: #555;
            text-decoration: none;
            transition: opacity 0.2s;
        }

        .switch-link span {
            color: #FF3B30; /* Робимо ключове слово фірмовим червоним */
            font-weight: 800;
            text-decoration: underline;
        }

        .switch-link:hover {
            opacity: 0.7;
        }
    </style>
</head>
<body>

    <div class="logo-container">
        <img src="/images/logo.png" class="brain-logo" alt="BrainBurst Logo">
        <h1 class="brand-title">BRAIN BURST</h1>
    </div>

    <form class="form-container" action="/Cards" method="get">
        <input type="text" class="input-field" placeholder="Введіть електронну пошту або ім’я користувача">
        <input type="password" class="input-field" placeholder="Введіть пароль">

        <button type="submit" class="btn-login">Увійти</button>
        <a href="/Account/Register" class="switch-link">Немає акаунту? <span>Зареєструватися</span></a>
    </form>

</body>
</html>