@{
    // Вимикаємо сайдбар, бо ця сторінка теж має бути чистою
    Layout = null;
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Реєстрація - BrainBurst</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            padding-top: 60px; /* Відступ зверху */
            font-family: 'Inter', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center; /* Центруємо все по горизонталі */
            background-color: white;
        }

        .logo-container {
            text-align: center;
            margin-bottom: 20px;
        }

        .brain-logo {
            width: 160px; /* Підганяй під свій файл logo.png */
            height: auto;
            margin-bottom: 10px;
        }

        .brand-title {
            color: #FF3B30;
            font-size: 52px;
            font-weight: 800;
            margin: 0 0 30px 0;
            letter-spacing: 1px;
        }

        .form-container {
            width: 450px; /* Ширина блоку з полями */
            display: flex;
            flex-direction: column;
            gap: 15px; /* Відстань між полями */
        }

        .dob-label {
            font-weight: 800;
            font-size: 14px;
            margin-bottom: -5px;
            margin-left: 5px;
            color: #000;
        }

        .dob-row {
            display: flex;
            gap: 15px; /* Відстань між днем, місяцем і роком */
        }

        .input-field {
            background-color: #D9D9D9; /* Світло-сірий колір полів */
            border: none;
            border-radius: 12px;
            padding: 16px 20px;
            font-size: 16px;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            color: #333;
            width: 100%;
            box-sizing: border-box;
            outline: none; /* Прибирає обводку при кліку */
        }

            .input-field::placeholder {
                color: #555; /* Трохи темніший текст плейсхолдера */
                font-weight: 600;
            }

        .dob-input {
            flex: 1; /* Робить так, щоб 3 поля дати займали однакову ширину */
        }

        .btn-register {
            background-color: black;
            color: white;
            border: none;
            border-radius: 12px;
            padding: 18px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            transition: opacity 0.2s;
        }

            .btn-register:hover {
                opacity: 0.8;
            }

        .switch-link {
            margin-top: 15px;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            color: #555;
            text-decoration: none;
            transition: opacity 0.2s;
        }

        .switch-link span {
            color: #FF3B30; /* Робимо ключове слово фірмовим червоним */
            font-weight: 800;
            text-decoration: underline;
        }

        .switch-link:hover {
            opacity: 0.7;
        }
    </style>
</head>
<body>

    <div class="logo-container">
        <img src="/images/logo.png" class="brain-logo" alt="BrainBurst Logo">
        <h1 class="brand-title">BRAIN BURST</h1>
    </div>

    <form class="form-container" action="/Cards" method="get">

        <div class="dob-label">Дата народження</div>
        <div class="dob-row">
            <input type="text" class="input-field dob-input" placeholder="День">
            <input type="text" class="input-field dob-input" placeholder="Місяць">
            <input type="text" class="input-field dob-input" placeholder="Рік">
        </div>

        <input type="email" class="input-field" placeholder="Введіть електронну пошту">
        <input type="text" class="input-field" placeholder="Введіть ім’я користувача">
        <input type="password" class="input-field" placeholder="Введіть пароль">

        <button type="submit" class="btn-register">Зареєструватися</button>
        <a href="/Account/Login" class="switch-link">Вже є акаунт? <span>Увійти</span></a>
    </form>

</body>
</html>